RPC_URL=http://127.0.0.1:8545
CHAIN_ID=46630
KEEPER_PRIVATE_KEY=0x...
SCRATCH_CORE_ADDRESS=0x...
RANDOMNESS_ADDRESS=0x...

# Optional — defaults shown
POLL_INTERVAL_MS=2000
STATE_FILE=./keeper-state.json
BUY_LOOKBACK_BLOCKS=10000
# eth_getLogs range per request — 10 is safe for free-tier providers
# (Alchemy's free tier hard-caps at 10); raise it if yours allows more.
LOGS_CHUNK_SIZE=10
# Pause between chunk requests so the initial BUY_LOOKBACK_BLOCKS catch-up
# scan (up to 1000 requests at the defaults above) doesn't burst past a
# free tier's requests-per-second limit too.
LOGS_CHUNK_DELAY_MS=150

# TokenTaxRouter.sol address — leave unset until $SCRATCH actually launches
# (script/LaunchScratchToken.s.sol). While unset, sweeping is skipped
# entirely. Once launched, set this and the keeper periodically checks its
# balance and calls sweep() to move accrued trading tax into ScratchCore's
# prize pools + the ops wallet.
TOKEN_TAX_ROUTER_ADDRESS=
# How often to check TokenTaxRouter's balance, in ms. Kept tight (10s) since
# getting trading tax into the prize pools quickly matters most right after
# launch, when they start at zero. Just a plain eth_getBalance call when
# there's nothing to sweep, so this is cheap even this often.
SWEEP_INTERVAL_MS=10000

# --- Dashboard cache / HTTP API ---
# Serves game stats, the live-wins feed, and the leaderboard as JSON so the
# web app doesn't have to re-scan chain history itself on every visitor's
# first load. Railway routes its public domain to whatever PORT binds to —
# set VITE_KEEPER_API_URL on Vercel to that domain once this is deployed.
PORT=3000
DASHBOARD_CACHE_FILE=./dashboard-cache.json
# How often to refresh ETH price / game stats / scan for new events, in ms.
DASHBOARD_SCAN_INTERVAL_MS=15000
# eth_getLogs range for the full-history scan (game stats/wins/leaderboard) —
# separate from LOGS_CHUNK_SIZE above since this covers the entire history
# since deploy, not just a recent lookback, so it wants your RPC's actual
# widest allowed range. Lower this (e.g. to 10) if your provider caps it
# like Alchemy's free tier does.
DASHBOARD_SCAN_CHUNK_BLOCKS=2000
DASHBOARD_SCAN_CHUNK_DELAY_MS=100
# CORS origin allowed to read the API above — "*" (default) is fine since
# everything served is already-public on-chain data with no auth involved.
CORS_ALLOW_ORIGIN=*

# --- X (Twitter) posting ---
# Leave all four blank until you have API access. The bot will just log
# "would tweet: ..." to the console instead of posting for real.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
