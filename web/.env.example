# All optional. Leave unset and the site runs in demo mode (Play.tsx
# simulates buy/scratch locally, no RPC calls at all). Set
# VITE_SCRATCH_CORE_ADDRESS once ScratchCore is actually deployed
# (see script/ScratchCore.s.sol) to switch Play.tsx over to the real
# address-input -> send ETH -> watch-chain flow.
VITE_RPC_URL=https://rpc.mainnet.chain.robinhood.com
VITE_CHAIN_ID=4663
VITE_SCRATCH_CORE_ADDRESS=

# Set both once $SCRATCH actually launches (script/LaunchScratchToken.s.sol)
# to switch on Flywheel's "$SCRATCH burned so far" stat. Deploy block is the
# block the launch tx landed in — printed by that script's own output.
VITE_SCRATCH_TOKEN_ADDRESS=
VITE_SCRATCH_TOKEN_DEPLOY_BLOCK=

# The keeper's dashboard-cache HTTP API (keeper/src/server.ts) — set to its
# public Railway domain to switch the Scoreboard and Leaderboard pages from
# demo mode over to instant real data (the keeper scans chain history
# continuously server-side; without this the pages fall back to mock data
# entirely, same as an unset VITE_SCRATCH_CORE_ADDRESS).
VITE_KEEPER_API_URL=
